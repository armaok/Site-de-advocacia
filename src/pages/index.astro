---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Teixeira & Okamura Advocacia — Direito à Saúde do Autista">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-fundo"></div>
    <div class="container hero-conteudo">
      <div class="hero-texto">
        <p class="hero-label fade-up fade-up-delay-1">Direito à Saúde do Autista</p>
        <h1 class="hero-titulo fade-up fade-up-delay-2">
          Você não<br />está sozinho.<br />
          <span class="destaque">Nunca mais.</span>
        </h1>
        <p class="hero-subtitulo fade-up fade-up-delay-3">
          Quando o plano nega, quando o sistema ignora, quando todos ao redor se encolhem —
          nós estamos aqui. Porque já estivemos no seu lugar.
        </p>
        <div class="hero-acoes fade-up fade-up-delay-4">
          <a
            href="https://wa.me/5543999590122?text=Olá%2C%20preciso%20de%20ajuda%20com%20direito%20à%20saúde%20do%20meu%20filho%20autista."
            class="btn btn-claro"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Falar com um advogado
          </a>
          <a href="#diferenciais" class="btn btn-secundario-claro">
            Por que nós
          </a>
        </div>
      </div>
      <div class="hero-simbolo fade-up fade-up-delay-3" aria-hidden="true">
        <div class="lotus-container">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="lotus-svg">
            <circle cx="100" cy="100" r="95" stroke="rgba(191,191,191,0.2)" stroke-width="1"/>
            <circle cx="100" cy="100" r="70" stroke="rgba(191,191,191,0.12)" stroke-width="1"/>
            <ellipse cx="100" cy="130" rx="22" ry="40" fill="rgba(191,191,191,0.15)" stroke="rgba(191,191,191,0.4)" stroke-width="1.5"/>
            <ellipse cx="70" cy="115" rx="18" ry="32" fill="rgba(191,191,191,0.1)" stroke="rgba(191,191,191,0.3)" stroke-width="1.5" transform="rotate(-20 70 115)"/>
            <ellipse cx="130" cy="115" rx="18" ry="32" fill="rgba(191,191,191,0.1)" stroke="rgba(191,191,191,0.3)" stroke-width="1.5" transform="rotate(20 130 115)"/>
            <ellipse cx="50" cy="110" rx="14" ry="24" fill="rgba(191,191,191,0.07)" stroke="rgba(191,191,191,0.2)" stroke-width="1" transform="rotate(-35 50 110)"/>
            <ellipse cx="150" cy="110" rx="14" ry="24" fill="rgba(191,191,191,0.07)" stroke="rgba(191,191,191,0.2)" stroke-width="1" transform="rotate(35 150 110)"/>
            <path d="M100 145 Q100 100 100 80" stroke="rgba(191,191,191,0.3)" stroke-width="1.5"/>
            <path d="M100 120 Q80 100 60 95" stroke="rgba(191,191,191,0.2)" stroke-width="1"/>
            <path d="M100 120 Q120 100 140 95" stroke="rgba(191,191,191,0.2)" stroke-width="1"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="hero-rodape">
      <div class="container hero-rodape-inner">
        <div class="hero-stat">
          <span class="stat-num">PR + SP</span>
          <span class="stat-label">Estados com casos ativos</span>
        </div>
        <div class="hero-divisor"></div>
        <div class="hero-stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">Foco em Direito da Saúde do Autista</span>
        </div>
        <div class="hero-divisor"></div>
        <div class="hero-stat">
          <span class="stat-num">Brasil</span>
          <span class="stat-label">Atuação em todo o território nacional</span>
        </div>
      </div>
    </div>
  </section>

  <!-- POR QUE ESPECIALIZADO FAZ DIFERENÇA -->
  <section class="secao" id="diferenciais">
    <div class="container">
      <div class="linha-decorativa"></div>
      <h2 class="titulo-secao">Por que um escritório especializado faz diferença</h2>
      <p class="subtitulo-secao">
        Não basta ter um bom advogado. Você precisa de um advogado que já viveu o que você está vivendo.
      </p>
      <div class="grid-diferenciais">
        <div class="diferencial-card">
          <div class="diferencial-icone">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3>O advogado generalista não conhece o universo autista</h3>
          <p>Ele pode ser excelente no que faz. Mas quando você precisa explicar o que é ABA, o que é uma crise de regulação sensorial, por que aquela terapia específica não pode ser substituída por outra — você está sozinho na sala.</p>
        </div>
        <div class="diferencial-card diferencial-destaque">
          <div class="diferencial-icone">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3>Aqui você não precisa explicar do zero</h3>
          <p>Sabemos o que é o TEA do lado de dentro. Sabemos o que está em jogo quando o plano nega. Sabemos a urgência que existe por trás de cada processo. Isso muda a velocidade e a qualidade da defesa.</p>
        </div>
        <div class="diferencial-card">
          <div class="diferencial-icone">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
            </svg>
          </div>
          <h3>A jurisprudência é nosso território</h3>
          <p>Acompanhamos de perto as decisões dos tribunais sobre direito à saúde do autista. Sabemos o que tem funcionado, o que tem mudado, e como usar isso a favor das famílias.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NOSSA HISTÓRIA -->
  <section class="secao secao-cinza" id="historia">
    <div class="container dois-col">
      <div class="col-texto">
        <div class="linha-decorativa"></div>
        <h2 class="titulo-secao">Nós já recebemos<br/>essa negativa.</h2>
        <p>
          Arnaldo Okamura é autista. Jady Teixeira é autista. Juntos, são pais de filhos autistas.
          Nos conhecemos na clínica onde nossos filhos fazem terapia — e foi lá que surgiu o escritório.
        </p>
        <p style="margin-top: 1rem;">
          Não somos advogados que escolheram uma especialidade em um catálogo.
          Somos famílias que aprenderam o direito para lutar pelos próprios filhos —
          e que agora lutam pelo seu também.
        </p>
        <p style="margin-top: 1rem;">
          Quando você chega até nós com uma negativa na mão, não precisa explicar
          o que é um ABA, uma fonoaudiologia, uma crise. Já sabemos.
          O que você precisa é de alguém que entenda essa dor —
          e que tenha coragem de ir brigar por você.
        </p>
        <a href="/sobre" class="btn btn-primario" style="margin-top: 2rem;">
          Conheça nossa história completa
        </a>
      </div>
      <div class="col-destaque">
        <div class="card-mote">
          <p class="mote-texto">Empatia de quem tem a mesma luta.</p>
          <div class="mote-linha"></div>
          <p class="mote-assinatura">Teixeira & Okamura Advocacia</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OS ADVOGADOS -->
  <section class="secao" id="advogados">
    <div class="container">
      <div class="linha-decorativa"></div>
      <h2 class="titulo-secao">Os advogados</h2>
      <p class="subtitulo-secao">Duas histórias, uma missão.</p>
      <div class="grid-socios">
        <div class="card-socio">
          <div class="socio-foto-placeholder">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="60" cy="45" r="22" fill="rgba(191,191,191,0.3)" stroke="rgba(191,191,191,0.5)" stroke-width="1.5"/>
              <path d="M20 105 C20 80 40 70 60 70 C80 70 100 80 100 105" fill="rgba(191,191,191,0.2)" stroke="rgba(191,191,191,0.4)" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="socio-info">
            <h3>Arnaldo Mamoru Okamura</h3>
            <p class="socio-titulo">Advogado — OAB/PR</p>
            <p class="socio-bio">Autista, casado com Vanessa — também autista — e pai de dois filhos autistas. Chegou ao direito da saúde pelo mesmo caminho que seus clientes: pela negativa, pela luta, pela necessidade de entender a lei para proteger quem ama.</p>
          </div>
        </div>
        <div class="card-socio">
          <div class="socio-foto-placeholder">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="60" cy="45" r="22" fill="rgba(191,191,191,0.3)" stroke="rgba(191,191,191,0.5)" stroke-width="1.5"/>
              <path d="M20 105 C20 80 40 70 60 70 C80 70 100 80 100 105" fill="rgba(191,191,191,0.2)" stroke="rgba(191,191,191,0.4)" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="socio-info">
            <h3>Jady Teixeira Carvalho</h3>
            <p class="socio-titulo">Advogada — OAB/PR</p>
            <p class="socio-bio">Autista e mãe do Saulo, uma criança autista. Conheceu Arnaldo na sala de espera da clínica onde seus filhos fazem terapia — e foi dessa conversa que nasceu o escritório.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ÁREAS DE ATUAÇÃO -->
  <section class="secao secao-cinza" id="atuacao">
    <div class="container">
      <div class="linha-decorativa"></div>
      <h2 class="titulo-secao">O que fazemos</h2>
      <p class="subtitulo-secao">
        Atuamos em todas as frentes do Direito à Saúde do Autista —
        contra planos de saúde e contra o Poder Público.
      </p>
      <div class="grid-atuacao">
        <div class="card-atuacao">
          <div class="card-icone">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3>Negativa de plano de saúde</h3>
          <p>O plano disse não. Na maioria dos casos, a lei diz sim.</p>
        </div>
        <div class="card-atuacao">
          <div class="card-icone">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9"/>
            </svg>
          </div>
          <h3>Ações contra o Poder Público</h3>
          <p>Quando o Estado nega o que a lei garante, é possível exigir judicialmente.</p>
        </div>
        <div class="card-atuacao">
          <div class="card-icone">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3>Terapias multidisciplinares</h3>
          <p>ABA, fonoaudiologia, terapia ocupacional, psicologia. O direito ao tratamento integral existe.</p>
        </div>
        <div class="card-atuacao">
          <div class="card-icone">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3>Redução de jornada</h3>
          <p>Servidores públicos pais de autistas têm direito à redução de carga horária.</p>
        </div>
        <div class="card-atuacao">
          <div class="card-icone">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3>Acesso a medicamentos</h3>
          <p>Quando o medicamento prescrito é negado, entramos com as medidas cabíveis.</p>
        </div>
        <div class="card-atuacao card-atuacao-cta">
          <p>Tem outra situação?</p>
          <p style="font-size: 0.85rem; margin-top: 0.5rem; opacity: 0.8;">Fale com a gente. Cada família tem uma história diferente.</p>
          <a
            href="https://wa.me/5543999590122?text=Olá%2C%20tenho%20uma%20dúvida%20sobre%20o%20direito%20do%20meu%20filho%20autista."
            class="btn btn-claro"
            target="_blank"
            rel="noopener noreferrer"
            style="margin-top: 1.5rem;"
          >
            Falar agora
          </a>
        </div>
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/atuacao" class="btn btn-secundario">Ver todas as áreas em detalhe</a>
      </div>
    </div>
  </section>

  <!-- PARA QUEM É -->
  <section class="secao secao-escura" id="para-quem">
    <div class="container">
      <div class="linha-decorativa"></div>
      <h2 class="titulo-secao">Se você se reconhece aqui, podemos ajudar</h2>
      <div class="grid-para-quem">
        <div class="item-para-quem">
          <span class="aspas">"</span>
          <p>O plano negou a cobertura do ABA do meu filho e não sei o que fazer."</p>
        </div>
        <div class="item-para-quem">
          <span class="aspas">"</span>
          <p>Sou servidora pública e preciso reduzir minha jornada para cuidar do meu filho, mas o RH não está cooperando."</p>
        </div>
        <div class="item-para-quem">
          <span class="aspas">"</span>
          <p>O médico prescreveu o medicamento, mas o plano diz que não está na lista de cobertura."</p>
        </div>
        <div class="item-para-quem">
          <span class="aspas">"</span>
          <p>Estou lutando sozinha. Minha família não entende. O plano não responde. Não sei mais para onde correr."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="secao" id="blog">
    <div class="container">
      <div class="linha-decorativa"></div>
      <h2 class="titulo-secao">Do blog</h2>
      <p class="subtitulo-secao">
        Informação clara para famílias atípicas. Sem juridiquês, sem enrolação.
      </p>
      <div class="blog-preview-grid">
        <article class="blog-card">
          <div class="blog-card-tag">Planos de saúde</div>
          <h3>O plano negou o ABA do seu filho. O que fazer agora?</h3>
          <p>Passo a passo prático para entender seus direitos e como agir após uma negativa de cobertura para terapia ABA.</p>
          <a href="/blog/plano-negou-aba-o-que-fazer" class="blog-card-link">Ler artigo →</a>
        </article>
        <article class="blog-card">
          <div class="blog-card-tag">Servidor público</div>
          <h3>Redução de jornada para pais de autistas: quem tem direito?</h3>
          <p>A lei garante esse direito, mas muitos servidores não sabem como exigir. Entenda o que diz a legislação.</p>
          <a href="/blog" class="blog-card-link">Ler artigo →</a>
        </article>
        <article class="blog-card">
          <div class="blog-card-tag">Direito à saúde</div>
          <h3>Lei Berenice Piana: o que ela garante na prática para as famílias?</h3>
          <p>A lei que protege os direitos das pessoas com autismo existe há mais de uma década. Conheça o que ela diz.</p>
          <a href="/blog" class="blog-card-link">Ler artigo →</a>
        </article>
      </div>
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/blog" class="btn btn-secundario">Ver todos os artigos</a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="secao-cta">
    <div class="container cta-inner">
      <h2>Sua luta tem apoio jurídico.</h2>
      <p>Fale com a gente. A primeira conversa é gratuita.</p>
      <a
        href="https://wa.me/5543999590122?text=Olá%2C%20vim%20pelo%20site%20e%20gostaria%20de%20conversar%20sobre%20meu%20caso."
        class="btn btn-claro"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Falar pelo WhatsApp
      </a>
    </div>
  </section>

</Layout>

<style>
  .hero {
    background-color: var(--bordô);
    padding-top: 72px;
    position: relative;
    overflow: hidden;
  }

  .hero-fundo {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 50%, rgba(143,26,16,0.6) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(90,15,9,0.5) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-conteudo {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    padding-top: 5rem;
    padding-bottom: 4rem;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--prata-escuro);
