---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categorias: Record<string, string> = {
  'planos-de-saude': 'Planos de saúde',
  'poder-publico': 'Poder Público',
  'terapias': 'Terapias',
  'medicamentos': 'Medicamentos',
  'servidor-publico': 'Servidor público',
  'direito-a-saude': 'Direito à saúde',
};

function formatarData(dataStr: any) {
  if (!dataStr) return '';
  const meses = ['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
  try {
    const data = new Date(dataStr);
    if (isNaN(data.getTime())) return '';
    const dia = data.getUTCDate();
    const mes = meses[data.getUTCMonth()];
    const ano = data.getUTCFullYear();
    return `${dia} de ${mes} de ${ano}`;
  } catch {
    return '';
  }
}
---

<Layout
  title="Blog — Teixeira & Okamura Advocacia"
  description="Informação clara para famílias atípicas. Direito à Saúde do Autista sem juridiquês, sem enrolação."
>

  <section class="topo-pagina">
    <div class="container">
      <p class="label-topo">Conhecimento</p>
      <h1>Informação é<br/>poder de luta.</h1>
      <p class="subtitulo-topo">
        Escrevemos para famílias atípicas — sem juridiquês, sem enrolação.
        Porque entender seu direito é o primeiro passo para exigi-lo.
      </p>
    </div>
  </section>

  <section class="secao">
    <div class="container">

      {posts.length === 0 ? (
        <p class="sem-posts">Em breve novos artigos. Volte logo.</p>
      ) : (
        <>
          <!-- POST DESTAQUE -->
          <article class="post-destaque">
            <div class="post-destaque-tag">{categorias[posts[0].data.categoria] || posts[0].data.categoria}</div>
            <h2 class="post-destaque-titulo">{posts[0].data.title}</h2>
            <p class="post-destaque-resumo">{posts[0].data.resumo}</p>
            <div class="post-destaque-rodape">
              <span class="post-data">{formatarData(posts[0].data.date)}</span>
              <a href={`/blog/${posts[0].slug}`} class="btn btn-claro">
                Ler artigo completo
              </a>
            </div>
          </article>

          <!-- GRADE DE POSTS -->
          {posts.length > 1 && (
            <div class="posts-grade">
              {posts.slice(1).map(post => (
                <article class="post-card">
                  <div class="post-card-top">
                    <span class="post-tag">{categorias[post.data.categoria] || post.data.categoria}</span>
                    <span class="post-data">{formatarData(post.data.date)}</span>
                  </div>
                  <h3 class="post-titulo">{post.data.title}</h3>
                  <p class="post-resumo">{post.data.resumo}</p>
                  <a href={`/blog/${post.slug}`} class="post-link">Ler artigo →</a>
                </article>
              ))}
            </div>
          )}
        </>
      )}

    </div>
  </section>

  <section class="secao secao-cinza" style="text-align: center;">
    <div class="container" style="max-width: 580px;">
      <div class="linha-decorativa" style="margin: 0 auto 1.5rem;"></div>
      <h2 class="titulo-secao">Tem uma dúvida específica?</h2>
      <p style="color: var(--cinza-medio); margin-bottom: 2rem;">
        Se você não encontrou o que procurava aqui, fale diretamente com a gente.
      </p>
      <a
        href="https://wa.me/5543999590122?text=Olá%2C%20li%20o%20blog%20e%20tenho%20uma%20dúvida%20sobre..."
        class="btn btn-primario"
        target="_blank"
        rel="noopener noreferrer"
      >
        Falar pelo WhatsApp
      </a>
    </div>
  </section>

</Layout>

<style>
  .topo-pagina {
    background-color: var(--bordô);
    padding: 8rem 0 5rem;
    margin-top: 72px;
  }

  .topo-pagina .label-topo {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--prata-claro);
    margin-bottom: 1rem;
  }

  .topo-pagina h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: var(--branco);
    font-weight: 500;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .subtitulo-topo {
    color: var(--prata-claro);
    font-size: 1rem;
    font-weight: 500;
    max-width: 580px;
  }

  .sem-posts {
    text-align: center;
    color: var(--cinza-medio);
    font-size: 1rem;
    padding: 3rem 0;
  }

  .post-destaque {
    background-color: var(--bordô);
    padding: 3rem;
    border-radius: 2px;
    margin-bottom: 3rem;
  }

  .post-destaque-tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prata-claro);
    margin-bottom: 1rem;
  }

  .post-destaque-titulo {
    font-family: var(--fonte-titulo);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--branco);
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .post-destaque-resumo {
    color: var(--prata-claro);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 680px;
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .post-destaque-rodape {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .post-data {
    font-size: 0.8rem;
    color: var(--prata-claro);
    font-weight: 400;
  }

  .posts-grade {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .post-card {
    border-bottom: 2px solid var(--prata-claro);
    padding-bottom: 2rem;
    transition: var(--transicao);
  }

  .post-card:hover { border-bottom-color: var(--bordô); }

  .post-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bordô);
  }

  .post-card .post-data {
    color: var(--cinza-medio);
  }

  .post-titulo {
    font-family: var(--fonte-corpo);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cinza-escuro);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .post-resumo {
    font-size: 0.95rem;
    color: var(--cinza-medio);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-weight: 500;
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--bordô);
    letter-spacing: 0.05em;
    transition: var(--transicao);
  }

  .post-link:hover { letter-spacing: 0.1em; }

  @media (max-width: 900px) {
    .posts-grade { grid-template-columns: repeat(2, 1fr); }
    .post-destaque { padding: 2rem; }
  }

  @media (max-width: 580px) {
    .posts-grade { grid-template-columns: 1fr; }
  }
</style>
