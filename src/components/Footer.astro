---
const anoAtual = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <span class="footer-logo-principal">Teixeira & Okamura</span>
      <span class="footer-logo-sub">Advocacia</span>
      <p class="footer-mote">Empatia armada pelo direito do seu filho.</p>
    </div>

    <div class="footer-col">
      <h4>Navegação</h4>
      <ul>
        <li><a href="/">Início</a></li>
        <li><a href="/sobre">Sobre o Escritório</a></li>
        <li><a href="/atuacao">Áreas de Atuação</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contato">Contato</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Atuação</h4>
      <ul>
        <li>Planos de saúde</li>
        <li>Poder Público</li>
        <li>Terapias multidisciplinares</li>
        <li>Redução de jornada</li>
        <li>Acesso a medicamentos</li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contato</h4>
      <ul>
        <li>
          <a href="mailto:contato@toadvocacia.com.br">
            contato@toadvocacia.com.br
          </a>
        </li>
        <li>
          <a href="https://wa.me/5543999590122" target="_blank" rel="noopener noreferrer">
            (43) 99959-0122
          </a>
        </li>
        <li>Londrina — PR</li>
        <li>Atuação em todo o Brasil</li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {anoAtual} Teixeira e Okamura Sociedade de Advogados. Todos os direitos reservados.</p>
      <p class="oab">OAB/PR — Este site tem finalidade informativa e não constitui consultoria jurídica.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bordô-escuro);
    color: var(--prata-claro);
    padding-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(191,191,191,0.15);
  }

  .footer-logo-principal {
    display: block;
    font-family: var(--fonte-titulo);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--prata-claro);
    letter-spacing: 0.02em;
    margin-bottom: 0.15rem;
  }

  .footer-logo-sub {
    display: block;
    font-family: var(--fonte-corpo);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--prata-escuro);
    margin-bottom: 1.25rem;
  }

  .footer-mote {
    font-size: 0.85rem;
    color: var(--prata-escuro);
    font-style: italic;
    font-weight: 300;
    line-height: 1.5;
  }

  .footer-col h4 {
    font-family: var(--fonte-corpo);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prata-escuro);
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col ul li,
  .footer-col ul a {
    font-size: 0.85rem;
    color: var(--prata-claro);
    opacity: 0.8;
    font-weight: 300;
    transition: var(--transicao);
  }

  .footer-col ul a:hover {
    opacity: 1;
    color: var(--branco);
  }

  .footer-bottom {
    padding: 1.5rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-bottom p {
    font-size: 0.72rem;
    color: var(--prata-escuro);
    opacity: 0.7;
    font-weight: 300;
  }

  .oab {
    font-style: italic;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 580px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
