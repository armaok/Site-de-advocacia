---
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const pathname = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Teixeira & Okamura Advocacia">
      <span class="logo-principal">Teixeira & Okamura</span>
      <span class="logo-sub">Advocacia</span>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <ul class="nav-lista">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) ? 'ativo' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="https://wa.me/5543999590122?text=Olá%2C%20vim%20pelo%20site%20e%20gostaria%20de%20falar%20com%20um%20advogado."
      class="btn-nav-wa"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar pelo WhatsApp"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="wa-label">Falar Agora</span>
    </a>

    <button class="menu-mobile" id="menuToggle" aria-label="Abrir menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Menu Mobile -->
  <div class="nav-mobile" id="navMobile">
    <ul>
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="nav-mobile-link">{link.label}</a>
        </li>
      ))}
      <li>
        <a
          href="https://wa.me/5543999590122?text=Olá%2C%20vim%20pelo%20site%20e%20gostaria%20de%20falar%20com%20um%20advogado."
          class="btn-primario btn"
          target="_blank"
          rel="noopener noreferrer"
          style="margin-top: 1rem; width: 100%; justify-content: center;"
        >
          Falar pelo WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--prata-claro);
    transition: var(--transicao);
  }

  .header.scrolled {
    box-shadow: 0 2px 20px rgba(117,22,13,0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 2rem;
  }

  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    flex-shrink: 0;
  }

  .logo-principal {
    font-family: var(--fonte-titulo);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--bordô);
    letter-spacing: 0.02em;
  }

  .logo-sub {
    font-family: var(--fonte-corpo);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--prata-escuro);
  }

  .nav-lista {
    display: flex;
    list-style: none;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: var(--fonte-corpo);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cinza-escuro);
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    position: relative;
    transition: var(--transicao);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 1.5px;
    background: var(--bordô);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .nav-link:hover,
  .nav-link.ativo {
    color: var(--bordô);
  }

  .nav-link:hover::after,
  .nav-link.ativo::after {
    transform: scaleX(1);
  }

  .btn-nav-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: #25D366;
    color: #fff;
    font-size: 0.88rem;
    font-weight: 700;
    padding: 0.55rem 1.1rem;
    border-radius: 2rem;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 2px 10px rgba(37,211,102,0.3);
    flex-shrink: 0;
    text-transform: none;
    letter-spacing: 0;
  }

  .btn-nav-wa:hover {
    background: #1da851;
    transform: translateY(-1px);
  }

  @media (max-width: 680px) {
    .wa-label { display: none; }
  }

  .menu-mobile {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-mobile span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--bordô);
    transition: var(--transicao);
  }

  .nav-mobile {
    display: none;
    padding: 1.5rem;
    border-top: 1px solid var(--prata-claro);
    background: var(--branco);
  }

  .nav-mobile ul {
    list-style: none;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.85rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--cinza-escuro);
    border-bottom: 1px solid var(--prata-claro);
    letter-spacing: 0.03em;
  }

  .nav-mobile-link:hover {
    color: var(--bordô);
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }
    .menu-mobile {
      display: flex;
    }
    .nav-mobile.aberto {
      display: block;
    }
  }
</style>

<script>
  const header = document.getElementById('header');
  const menuToggle = document.getElementById('menuToggle');
  const navMobile = document.getElementById('navMobile');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  menuToggle?.addEventListener('click', () => {
    const isOpen = navMobile?.classList.toggle('aberto');
    menuToggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
